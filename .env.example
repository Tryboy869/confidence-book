# ========== DATABASE (Turso - LibSQL) ==========
# Créer un compte gratuit sur https://turso.tech
# Commandes:
#   turso db create confidence-book
#   turso db show confidence-book
DATABASE_URL=libsql://confidence-book-xxxxx.turso.io
DATABASE_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# ========== AI MODERATION (Groq - 5 modèles en fallback) ==========
# Créer un compte gratuit sur https://console.groq.com
# Modèles utilisés:
#   1. llama-3.3-70b-versatile (précis)
#   2. llama-3.1-8b-instant (rapide)
#   3. gemma2-9b-it
#   4. mixtral-8x7b-32768
#   5. llama3-groq-70b-8192-tool-use-preview
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== DEPLOYMENT NOTES ==========
# Sur Render/Railway:
# - Le PORT est automatiquement fourni
# - Ajouter les variables DATABASE_URL, DATABASE_AUTH_TOKEN, GROQ_API_KEY dans Settings
# - Build Command: npm install
# - Start Command: node api.js

# ========== LOCAL DEVELOPMENT ==========
# En local sans clés API:
# - La modération sera skippée (dev mode)
# - Une base SQLite locale sera créée (local.db)

# ⚠️ IMPORTANT:
# - Ne JAMAIS commit le fichier .env
# - Copier ce fichier vers .env et remplir les valeurs réelles