# Database (Turso)
DATABASE_URL=libsql://your-database-url.turso.io
DATABASE_AUTH_TOKEN=your_auth_token_here

# AI Moderation (Groq)
GROQ_API_KEY=your_groq_api_key_here

# Admin
ADMIN_KEY=your_super_secret_admin_key_here

# Environment
NODE_ENV=production
PORT=3000

# Reset Database (set to "true" to enable reset on startup - DANGER!)
RESET_DB=true
