# ========== TURSO DATABASE ==========
# Obtenir sur: https://turso.tech/app
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# ========== GROQ AI ==========
# Obtenir sur: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# ========== PORT (NE PAS DÉFINIR EN PRODUCTION) ==========
# Render/Railway définissent PORT automatiquement
# PORT=3000  # <- Ne décommenter QUE pour dev local

# ========== NOTES ==========
# 1. Copier ce fichier en .env pour dev local
# 2. Ne JAMAIS commit .env (déjà dans .gitignore)
# 3. Variables production = définir dans Render Dashboard
# 4. Modèle IA par défaut: llama-3.3-70b-versatile
# 5. Fallback automatique vers llama-3.1 ou mixtral